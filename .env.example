# Flask / Render
# PORT=5000
# CORS_ORIGIN=*

# Upload and analysis config
# STORE_UPLOADS=true
# MAX_UPLOAD_SIZE_MB=10
# ANOMALY_CONTAMINATION=0.08

# PDF parser mode: pymupdf | azure
# PDF_PARSER=azure

# Azure Blob Storage
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=...
# AZURE_STORAGE_CONTAINER_NAME=expense-uploads

# Azure Document Intelligence
# AZURE_DOC_INTELLIGENCE_ENDPOINT=https://<resource>.cognitiveservices.azure.com/
# AZURE_DOC_INTELLIGENCE_KEY=...

# Gemini API (free tier)
# GEMINI_API_KEY=

# Optional legacy Azure OpenAI variables (unused if Gemini is active)
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_DEPLOYMENT=

